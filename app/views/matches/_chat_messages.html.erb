<% if messages.any? %>
  <div class="match-chat-list">
    <% messages.each do |message| %>
      <div class="match-chat-message">
        <div class="match-chat-meta">
          <strong><%= message.user.name %></strong>
          <span><%= l(message.created_at, format: :short) %></span>
        </div>
        <p><%= message.body %></p>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="match-chat-empty">
    <p class="font-black text-slate-900">Ainda sem resenha por aqui.</p>
    <p class="muted">Puxe o assunto e deixe sua corneta registrada.</p>
  </div>
<% end %>

<div class="actions">
  <div>
    <p class="page-kicker">⚽ Rodada da Copa</p>
    <h1 class="page-title">Jogos pra meter o palpite 🔥</h1>
  </div>
  <% if current_user.admin? %>
    <%= button_to "Sincronizar placares ⚡", admin_sync_path, method: :post %>
  <% end %>
</div>

<% if @matches.any? %>
  <div class="hype-card mb-4">
    <p class="text-lg font-black text-slate-950">Hoje tem resenha: escolhe o placar, aposta ADcoins e prepara a corneta. 😎</p>
    <p class="muted">Palpite bom vira moral. Palpite ruim vira print no grupo.</p>
  </div>

  <div class="table-shell overflow-x-auto">
    <table class="data-table">
      <thead>
        <tr>
          <th>Partida</th>
          <th>Quando</th>
          <th>Clima</th>
          <th>Placar</th>
          <th>Sua ousadia</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @matches.each do |match| %>
          <% prediction = @predictions_by_match_id[match.id] %>
          <tr>
            <td>
              <div class="font-black text-slate-950"><%= match.home_team.name %></div>
              <div class="text-xs font-bold uppercase text-slate-400">x sem amizade</div>
              <div class="font-black text-slate-950"><%= match.away_team.name %></div>
            </td>
            <td class="font-semibold text-slate-700"><%= l(match.kickoff_at, format: :short) %></td>
            <td>
              <span class="status-pill <%= match.open_for_predictions? ? "status-open" : "status-closed" %>"><%= match.open_for_predictions? ? "Aberto 🔥" : "#{match.status} 😬" %></span>
            </td>
            <td><span class="score-pill"><%= match.home_score.nil? ? "-" : "#{match.home_score} x #{match.away_score}" %></span></td>
            <td class="font-bold text-slate-700"><%= prediction ? "#{prediction.home_score} x #{prediction.away_score} 🎯" : "Sem palpite 👀" %></td>
            <td class="text-right"><%= link_to match.open_for_predictions? ? "Palpitar 🚀" : "Ver resenha", match_path(match), class: "button" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="panel-muted">
    <p class="font-black text-slate-900">Nenhum jogo cadastrado ainda. 🥲</p>
    <p class="muted">Configure a API e use a sincronizacao, ou cadastre dados via console Rails durante o desenvolvimento.</p>
  </div>
<% end %>

<div class="actions">
  <div>
    <p class="page-kicker">Copa do Mundo 2026</p>
    <h1 class="page-title">Jogos em destaque</h1>
  </div>
  <% if current_user.admin? %>
    <%= button_to "Sincronizar placares", admin_sync_path, method: :post %>
  <% end %>
</div>

<div class="quick-nav">
  <%= link_to "📅 Calendário completo", calendar_matches_path, class: "button-secondary" %>
  <%= link_to "📊 Fase de grupos", groups_matches_path, class: "button-secondary" %>
  <%= link_to "🗂️ Chaveamento", bracket_matches_path, class: "button-secondary" %>
</div>

<% if @matches.any? %>
  <section class="match-section">
    <div class="section-heading">
      <div>
        <p class="page-kicker">Hoje</p>
        <h2>Jogos do dia</h2>
      </div>
      <span class="count-pill"><%= @today_matches.size %></span>
    </div>

    <% if @today_matches.any? %>
      <div class="match-grid">
        <% @today_matches.each do |match| %>
          <%= render "match_card", match: match, prediction: @predictions_by_match_id[match.id] %>
        <% end %>
      </div>
    <% else %>
      <div class="panel-muted">
        <p class="font-black text-slate-900">Nenhum jogo marcado para hoje.</p>
        <p class="muted">Os próximos confrontos em destaque aparecem logo abaixo.</p>
      </div>
    <% end %>
  </section>

  <section class="match-section">
    <div class="section-heading">
      <div>
        <p class="page-kicker">Agenda</p>
        <h2>Próximos jogos</h2>
      </div>
      <span class="count-pill"><%= @highlight_matches.size %></span>
    </div>

    <% if @highlight_matches.any? %>
      <div class="match-grid">
        <% @highlight_matches.each do |match| %>
          <%= render "match_card", match: match, prediction: @predictions_by_match_id[match.id] %>
        <% end %>
      </div>
      <div class="section-actions">
        <%= link_to "📅 Ver calendário completo", calendar_matches_path, class: "button" %>
      </div>
    <% else %>
      <div class="panel-muted">
        <p class="font-black text-slate-900">Não há próximos jogos cadastrados.</p>
        <p class="muted">Use a sincronização para atualizar a agenda.</p>
      </div>
    <% end %>
  </section>
<% else %>
  <div class="panel-muted">
    <p class="font-black text-slate-900">Nenhum jogo cadastrado ainda.</p>
    <p class="muted">Configure a API e use a sincronização para importar a Copa do Mundo.</p>
  </div>
<% end %>

<%= render "live_score_polling" %>

<% if live_stats.present? && live_stats[:rows].present? %>
  <div class="mb-4 flex flex-col gap-1 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="page-kicker">ao vivo</p>
      <h2 class="text-xl font-black text-slate-950">Estatisticas da partida</h2>
    </div>
    <% if live_stats[:shot_count].to_i.positive? %>
      <span class="muted"><%= live_stats[:shot_count] %> finalizacoes mapeadas</span>
    <% end %>
  </div>

  <div class="table-shell overflow-x-auto">
    <table class="data-table">
      <thead>
        <tr>
          <th><%= match.home_team.name %></th>
          <th>Indicador</th>
          <th class="text-right"><%= match.away_team.name %></th>
        </tr>
      </thead>
      <tbody>
        <% live_stats[:rows].each do |row| %>
          <tr>
            <td class="font-black text-emerald-800"><%= row[:home_label] %></td>
            <td class="font-bold text-slate-700"><%= row[:label] %></td>
            <td class="text-right font-black text-amber-700"><%= row[:away_label] %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

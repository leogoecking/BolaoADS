<% prediction = local_assigns[:prediction] %>

<article class="match-card <%= "border-emerald-200 bg-emerald-50" if match.live? %>">
  <% if match.open_for_predictions? %>
    <button type="button" class="match-card-button" data-modal-open="quick-prediction-modal-<%= match.id %>">
      <%= render "matches/match_card_content", match: match, prediction: prediction %>
    </button>
    <%= render "quick_prediction_modal", match: match, prediction: prediction, return_to: request.fullpath %>
  <% else %>
    <%= link_to match_path(match), class: "block text-slate-900 hover:text-slate-950" do %>
      <%= render "matches/match_card_content", match: match, prediction: prediction %>
    <% end %>
  <% end %>
</article>

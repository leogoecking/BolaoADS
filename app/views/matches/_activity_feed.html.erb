<section id="mural" class="match-section">
  <% if local_assigns.fetch(:show_heading, true) %>
    <div class="section-heading">
      <div>
        <p class="page-kicker">💬 Mural</p>
        <h2>Atividades do bolao</h2>
      </div>
      <span class="count-pill"><%= activity_events.size %></span>
    </div>
  <% end %>

  <% if activity_events.any? %>
    <div class="activity-list">
      <% activity_events.each do |event| %>
        <% prediction = event.prediction %>
        <% reaction_counts = event.reaction_counts %>
        <% reacted_types = event.activity_event_reactions.select { |reaction| reaction.user_id == current_user.id }.map(&:reaction_type) %>
        <article class="activity-item">
          <% activity_icon = {
            "exact_score" => [ "🎯", "Placar exato" ],
            "leader_changed" => [ "👑", "Novo lider" ],
            "ranking_drop" => [ "📉", "Queda no ranking" ],
            "only_believer" => [ "🙋", "Unico pontuador" ],
            "no_hits" => [ "😵", "Ninguem cravou" ],
            "big_climb" => [ "🚀", "Maior subida" ],
            "underdog_hit" => [ "⚡", "Acerto de zebra" ]
          }.fetch(event.event_type, [ "💬", "Atividade" ]) %>
          <div class="activity-icon" title="<%= activity_icon.second %>" aria-label="<%= activity_icon.second %>"><%= activity_icon.first %></div>
          <div class="activity-body">
            <div class="activity-meta">
              <span><%= l(event.created_at, format: :short) %></span>
              <span><%= event.match.home_team.name %> x <%= event.match.away_team.name %></span>
            </div>

            <p class="activity-message"><%= event.message %></p>

            <% if prediction&.match&.predictions_revealed? %>
              <div class="activity-prediction">
                <span class="font-black"><%= prediction.user.name %></span>
                <span class="score-pill"><%= prediction.home_score %> x <%= prediction.away_score %></span>
                <span class="font-black text-emerald-800"><%= prediction.points %> pts</span>
              </div>
            <% end %>

            <div class="reaction-list">
              <% ActivityEventReaction::REACTION_TYPES.each do |reaction_type| %>
                <% reacted = reacted_types.include?(reaction_type) %>
                <% label = { "kkkk" => "😂 kkkk", "cornetou" => "📣 cornetou", "zicou" => "🧿 zicou", "genio" => "🧠 genio", "pipocou" => "🍿 pipocou" }.fetch(reaction_type) %>
                <%= button_to activity_event_reaction_path(event, reaction_type: reaction_type),
                      method: reacted ? :delete : :post,
                      class: "reaction-button #{'reaction-button-active' if reacted}",
                      title: reacted ? "Remover #{label}" : "Reagir com #{label}" do %>
                  <span><%= label %></span>
                  <strong><%= reaction_counts.fetch(reaction_type, 0) %></strong>
                <% end %>
              <% end %>
            </div>

            <div class="comment-list">
              <% event.activity_event_comments.sort_by(&:created_at).each do |comment| %>
                <div class="comment-item">
                  <strong><%= comment.user.name %></strong>
                  <span><%= comment.body %></span>
                </div>
              <% end %>
            </div>

            <%= form_with model: [event, ActivityEventComment.new], url: activity_event_comments_path(event), class: "comment-form" do |form| %>
              <%= form.text_field :body, maxlength: 280, required: true, placeholder: "Mandar resenha" %>
              <%= form.submit "Resenhar" %>
            <% end %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="panel-muted">
      <p class="font-black text-slate-900">O mural ainda esta quieto.</p>
      <p class="muted">Quando os jogos forem finalizados, os acertos, viradas e quedas aparecem aqui.</p>
    </div>
  <% end %>
</section>

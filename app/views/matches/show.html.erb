<div class="mb-4">
  <%= link_to "Voltar aos jogos", matches_path, class: "button-secondary" %>
</div>

<div class="panel">
  <div class="grid gap-5 lg:grid-cols-[1fr_auto_1fr] lg:items-center">
    <div>
      <p class="page-kicker">Mandante</p>
      <h1 class="text-3xl font-black text-slate-950"><%= @match.home_team.name %></h1>
    </div>
    <div class="stadium-score">
      <p class="text-xs font-black uppercase text-emerald-100">placar da treta</p>
      <p class="text-4xl font-black"><%= @match.score_label %></p>
      <p class="text-xs font-bold text-amber-200"><%= @match.live_clock_label.presence || "sem clubismo aqui... talvez" %></p>
    </div>
    <div class="lg:text-right">
      <p class="page-kicker">Visitante</p>
      <h1 class="text-3xl font-black text-slate-950"><%= @match.away_team.name %></h1>
    </div>
  </div>

  <div class="stat-grid mt-6">
    <div class="stat-card">
      <p class="muted">Inicio</p>
      <p class="font-black text-slate-950"><%= l(@match.kickoff_at, format: :long) %></p>
    </div>
    <div class="stat-card">
      <p class="muted">Palpites ate</p>
      <p class="font-black text-slate-950"><%= l(@match.prediction_deadline, format: :long) %></p>
    </div>
    <div class="stat-card">
      <p class="muted">Saldo pra ousar</p>
      <p class="font-black text-amber-700"><%= current_user.adcoins_balance %> ADcoins</p>
    </div>
  </div>

  <div class="mt-5">
    <span class="status-pill <%= @match.open_for_predictions? || @match.live? ? "status-open" : "status-closed" %>"><%= @match.open_for_predictions? ? "Aberto pra corneta" : @match.status_label %></span>
  </div>

  <%= render "shared/errors", object: @prediction %>

  <% if @match.open_for_predictions? %>
    <%= form_with model: [@match, @prediction], url: match_prediction_path(@match), method: (@prediction.persisted? ? :patch : :post) do |form| %>
      <div class="score-inputs mt-4 border-t border-slate-200 pt-4">
        <div>
          <%= form.label :home_score, @match.home_team.name %>
          <%= form.number_field :home_score, min: 0, required: true %>
        </div>
        <div>
          <%= form.label :away_score, @match.away_team.name %>
          <%= form.number_field :away_score, min: 0, required: true %>
        </div>
        <div>
          <%= form.label :adcoins_wager, "ADcoins na mesa" %>
          <%= form.number_field :adcoins_wager, min: 0, max: current_user.adcoins_balance + @prediction.adcoins_wager.to_i, required: true %>
        </div>
        <%= form.submit "Cravar palpite" %>
      </div>
    <% end %>
  <% elsif @prediction.persisted? %>
    <div class="mt-4 rounded-lg border border-slate-200 bg-slate-50 p-4">
      <p>Seu palpite ficou registrado: <strong><%= @prediction.home_score %> x <%= @prediction.away_score %></strong></p>
      <p>ADcoins na emocao: <strong><%= @prediction.adcoins_wager %></strong></p>
    </div>
    <p class="muted">Edicao encerrada. Agora e torcer e aguentar a resenha.</p>
  <% else %>
    <p class="muted">Palpites encerrados. Quem mandou dormir no ponto?</p>
  <% end %>
</div>

<div class="panel mt-4">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="page-kicker">detalhes</p>
      <h2 class="text-xl font-black text-slate-950">Mais informacoes do jogo</h2>
    </div>
    <div class="flex flex-wrap gap-2">
      <% if @live_stats.present? && @live_stats[:rows].present? %>
        <button type="button" class="button-secondary" data-modal-open="match-stats-modal">Ver estatisticas</button>
      <% end %>
      <button type="button" class="button-secondary" data-modal-open="match-predictions-modal">Ver palpites</button>
      <button type="button" class="button" data-chat-open>
        Resenha
        <% if @match_messages.any? %>
          <span class="ml-2 rounded-md bg-amber-300 px-2 py-0.5 text-xs font-black text-emerald-950"><%= @match_messages.size %></span>
        <% end %>
      </button>
    </div>
  </div>
</div>

<dialog id="match-stats-modal" class="match-modal">
  <div class="match-modal-card">
    <div class="match-modal-header">
      <div>
        <p class="page-kicker">detalhes</p>
        <h2 class="text-xl font-black text-slate-950">Estatisticas</h2>
      </div>
      <button type="button" class="match-modal-close" data-modal-close aria-label="Fechar">x</button>
    </div>
    <div class="match-modal-body">
      <%= render "matches/live_match_stats", match: @match, live_stats: @live_stats %>
    </div>
  </div>
</dialog>

<dialog id="match-predictions-modal" class="match-modal">
  <div class="match-modal-card">
    <div class="match-modal-header">
      <div>
        <p class="page-kicker">bolao</p>
        <h2 class="text-xl font-black text-slate-950">Palpites</h2>
      </div>
      <button type="button" class="match-modal-close" data-modal-close aria-label="Fechar">x</button>
    </div>
    <div class="match-modal-body">
      <%= render "matches/predictions_modal_content", match: @match, revealed_predictions: Array(@revealed_predictions) %>
    </div>
  </div>
</dialog>

<div class="panel mt-4">
  <div class="mb-4 flex flex-col gap-1 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="page-kicker">ao vivo</p>
      <h2 class="text-xl font-black text-slate-950">Lances importantes</h2>
    </div>
    <% if @match.live_incidents_synced_at.present? %>
      <span class="muted">Atualizado em <%= l(@match.live_incidents_synced_at, format: :short) %></span>
    <% end %>
  </div>

  <% incidents = @match.important_live_incidents %>
  <% if incidents.any? %>
    <div class="timeline-list">
      <% incidents.each do |incident| %>
        <div class="timeline-item">
          <span class="timeline-minute"><%= @match.incident_minute_label(incident) %></span>
          <div class="min-w-0">
            <p class="font-black text-slate-950"><%= @match.incident_title(incident) %></p>
            <% if @match.incident_meta(incident).present? %>
              <p class="muted"><%= @match.incident_meta(incident) %></p>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="muted">Nenhum lance importante disponivel para esta partida ainda.</p>
  <% end %>
</div>

<%= render "matches/live_score_polling" %>
<%= render "matches/chat_drawer", match: @match, messages: @match_messages, message: @match_message %>

<% content_for :body_scripts do %>
  <script>
    (() => {
      const chatDrawer = document.getElementById("match-chat-drawer");
      const chatOpen = document.querySelector("[data-chat-open]");
      const chatClose = chatDrawer?.querySelector("[data-chat-close]");
      const chatMessages = document.getElementById("match-chat-messages");
      const chatForm = chatDrawer?.querySelector("[data-chat-form]");
      const chatInput = chatForm?.querySelector("textarea");
      let chatInterval = null;

      async function refreshChat() {
        if (!chatMessages || chatDrawer?.hidden) return;

        const response = await fetch(chatMessages.dataset.chatMessagesUrl, {
          headers: { "Accept": "text/html" },
          cache: "no-store",
          credentials: "same-origin"
        });
        if (response.ok) {
          chatMessages.innerHTML = await response.text();
          chatMessages.scrollTop = chatMessages.scrollHeight;
        }
      }

      function openChat() {
        if (!chatDrawer) return;

        chatDrawer.hidden = false;
        chatMessages.scrollTop = chatMessages.scrollHeight;
        refreshChat();
        chatInterval ||= window.setInterval(refreshChat, 5000);
      }

      function closeChat() {
        if (!chatDrawer) return;

        chatDrawer.hidden = true;
        if (chatInterval) {
          window.clearInterval(chatInterval);
          chatInterval = null;
        }
      }

      chatOpen?.addEventListener("click", openChat);
      chatClose?.addEventListener("click", closeChat);

      chatInput?.addEventListener("keydown", (event) => {
        if (event.key !== "Enter" || event.shiftKey || event.isComposing) return;
        if (chatInput.value.trim().length === 0) return;

        event.preventDefault();
        chatForm.requestSubmit();
      });

      chatForm?.addEventListener("submit", async (event) => {
        event.preventDefault();
        const response = await fetch(chatForm.action, {
          method: "POST",
          body: new FormData(chatForm),
          headers: {
            "Accept": "text/html",
            "X-Requested-With": "XMLHttpRequest",
            "X-CSRF-Token": document.querySelector("meta[name='csrf-token']")?.content
          },
          credentials: "same-origin"
        });

        if (response.ok) {
          chatMessages.innerHTML = await response.text();
          chatForm.reset();
          chatMessages.scrollTop = chatMessages.scrollHeight;
        }
      });
    })();
  </script>
<% end %>

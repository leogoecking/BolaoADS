<div class="mb-4">
  <%= link_to "⬅️ Voltar aos jogos", matches_path, class: "button-secondary" %>
</div>

<div class="panel">
  <div class="grid gap-5 lg:grid-cols-[1fr_auto_1fr] lg:items-center">
    <div>
      <p class="page-kicker">🏠 Mandante</p>
      <h1 class="text-3xl font-black text-slate-950"><%= @match.home_team.name %></h1>
    </div>
    <div class="stadium-score">
      <p class="text-xs font-black uppercase text-emerald-100">placar da treta</p>
      <p class="text-4xl font-black"><%= @match.home_score.nil? ? "-" : "#{@match.home_score} x #{@match.away_score}" %></p>
      <p class="text-xs font-bold text-amber-200"><%= @match.live_clock_label.presence || "sem clubismo aqui... talvez 😅" %></p>
    </div>
    <div class="lg:text-right">
      <p class="page-kicker">🚌 Visitante</p>
      <h1 class="text-3xl font-black text-slate-950"><%= @match.away_team.name %></h1>
    </div>
  </div>

  <div class="stat-grid mt-6">
    <div class="stat-card">
      <p class="muted">⏰ Inicio</p>
      <p class="font-black text-slate-950"><%= l(@match.kickoff_at, format: :long) %></p>
    </div>
    <div class="stat-card">
      <p class="muted">🚨 Palpites ate</p>
      <p class="font-black text-slate-950"><%= l(@match.prediction_deadline, format: :long) %></p>
    </div>
    <div class="stat-card">
      <p class="muted">🪙 Saldo pra ousar</p>
      <p class="font-black text-amber-700"><%= current_user.adcoins_balance %> ADcoins</p>
    </div>
  </div>

  <% if @match.live_clock_label.present? %>
    <div class="mt-4 rounded-lg border border-emerald-200 bg-emerald-50 p-4">
      <p class="text-xs font-black uppercase text-emerald-700">tempo do jogo</p>
      <p class="text-lg font-black text-emerald-950"><%= @match.live_clock_label %></p>
      <% if @match.last_synced_at.present? %>
        <p class="muted">Atualizado em <%= l(@match.last_synced_at, format: :short) %></p>
      <% end %>
    </div>
  <% end %>

  <div class="mt-5">
    <span class="status-pill <%= @match.open_for_predictions? ? "status-open" : "status-closed" %>"><%= @match.open_for_predictions? ? "Aberto pra corneta 🔥" : "#{@match.status} 😬" %></span>
  </div>

  <%= render "shared/errors", object: @prediction %>

  <% if @match.open_for_predictions? %>
    <%= form_with model: [@match, @prediction], url: match_prediction_path(@match), method: (@prediction.persisted? ? :patch : :post) do |form| %>
      <div class="score-inputs mt-4 border-t border-slate-200 pt-4">
        <div>
          <%= form.label :home_score, @match.home_team.name %>
          <%= form.number_field :home_score, min: 0, required: true %>
        </div>
        <div>
          <%= form.label :away_score, @match.away_team.name %>
          <%= form.number_field :away_score, min: 0, required: true %>
        </div>
        <div>
          <%= form.label :adcoins_wager, "ADcoins na mesa 🪙" %>
          <%= form.number_field :adcoins_wager, min: 0, max: current_user.adcoins_balance + @prediction.adcoins_wager.to_i, required: true %>
        </div>
        <%= form.submit "Cravar palpite 🚀" %>
      </div>
    <% end %>
  <% elsif @prediction.persisted? %>
    <div class="mt-4 rounded-lg border border-slate-200 bg-slate-50 p-4">
      <p>Seu palpite ficou registrado: <strong><%= @prediction.home_score %> x <%= @prediction.away_score %> 🎯</strong></p>
      <p>ADcoins na emoção: <strong><%= @prediction.adcoins_wager %> 🪙</strong></p>
    </div>
    <p class="muted">Edicao encerrada. Agora e torcer e aguentar a resenha.</p>
  <% else %>
    <p class="muted">Palpites encerrados. Quem mandou dormir no ponto? 😬</p>
  <% end %>
</div>

<% if @match.predictions_revealed? %>
  <div class="panel mt-4">
    <h2 class="mb-4 text-xl font-black text-slate-950">Palpites revelados: hora do julgamento 🧾</h2>
    <% if @revealed_predictions.any? %>
      <div class="table-shell overflow-x-auto">
        <table class="data-table">
          <thead>
            <tr>
              <th>Participante</th>
              <th>Cravada</th>
              <th>ADcoins</th>
              <th>Pontos</th>
            </tr>
          </thead>
          <tbody>
            <% @revealed_predictions.each do |prediction| %>
              <tr>
                <td class="font-black"><%= prediction.user.name %></td>
                <td><span class="score-pill"><%= prediction.home_score %> x <%= prediction.away_score %></span></td>
                <td class="font-bold text-amber-700"><%= prediction.adcoins_wager %> 🪙</td>
                <td class="font-black text-emerald-800"><%= prediction.points %> 🔥</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="muted">Ninguem palpitou nesta partida. A coragem passou longe.</p>
    <% end %>
  </div>
<% else %>
  <div class="panel mt-4">
    <h2 class="text-xl font-black text-slate-950">Palpites secretos 🤫</h2>
    <p class="muted">Os palpites dos outros participantes ficam escondidos ate a bola rolar. Sem copiar a call do coleguinha.</p>
  </div>
<% end %>

<div class="panel mt-4">
  <div class="mb-4 flex flex-col gap-1 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="page-kicker">ao vivo</p>
      <h2 class="text-xl font-black text-slate-950">Lances importantes</h2>
    </div>
    <% if @match.live_incidents_synced_at.present? %>
      <span class="muted">Atualizado em <%= l(@match.live_incidents_synced_at, format: :short) %></span>
    <% end %>
  </div>

  <% incidents = @match.live_incident_list.first(12) %>
  <% if incidents.any? %>
    <div class="timeline-list">
      <% incidents.each do |incident| %>
        <div class="timeline-item">
          <span class="timeline-minute"><%= incident["minute"].present? ? "#{incident["minute"]}'" : "--" %></span>
          <div class="min-w-0">
            <p class="font-black text-slate-950"><%= incident["text"].presence || incident["type"].to_s.humanize %></p>
            <p class="muted"><%= [incident["type"], incident["home_score"].nil? ? nil : "#{incident["home_score"]} x #{incident["away_score"]}"].compact.join(" · ") %></p>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="muted">Nenhum lance importante disponivel para esta partida ainda.</p>
  <% end %>
</div>

<%= render "live_score_polling" %>

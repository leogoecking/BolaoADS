<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title>BolaoADS</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  </head>
  <body class="app-shell">
    <header class="topbar">
      <div class="topbar-inner">
        <%= link_to root_path, class: "brand-lockup text-white hover:text-white" do %>
          <span class="brand-mark">⚽</span>
          <span>
            <span class="block text-lg font-black leading-tight">BolaoADS</span>
            <span class="block text-xs font-bold uppercase text-emerald-100">resenha, corneta e ADcoins</span>
          </span>
        <% end %>

        <% if signed_in? %>
          <div class="topbar-menu">
            <nav class="nav-list">
              <%= link_to "💬 Mural", mural_path, class: "nav-link" %>
              <%= link_to "⚽ Jogos", matches_path, class: "nav-link" %>
              <%= link_to "📅 Calendário", calendar_matches_path, class: "nav-link" %>
              <%= link_to "📊 Grupos", groups_matches_path, class: "nav-link" %>
              <%= link_to "🏆 Ranking", ranking_path, class: "nav-link" %>
              <%= link_to "🔮 Especiais", special_predictions_path, class: "nav-link" %>
              <%= link_to "🔥 Conquistas", achievements_path, class: "nav-link" %>
              <%= link_to "🗂️ Chaveamento", bracket_matches_path, class: "nav-link" %>
            </nav>
            <div class="account-bar">
              <span class="coin-chip">🪙 <%= current_user.adcoins_balance %> ADcoins</span>
              <span class="user-chip" title="<%= current_user.name %>">😎 <%= current_user.name %></span>
              <%= button_to "🚪", session_path, method: :delete, class: "topbar-logout", title: "Sair", aria: { label: "Sair" }, form_class: "logout-form" %>
            </div>
          </div>
        <% else %>
          <nav class="nav-list">
            <%= link_to "Entrar 👀", new_session_path, class: "nav-link" %>
            <%= link_to "Cadastrar e cornetar 🔥", new_registration_path, class: "button bg-amber-300 text-emerald-950 hover:bg-amber-200" %>
          </nav>
        <% end %>
      </div>
    </header>

    <main class="page-wrap">
      <% if notice.present? %><div class="flash"><%= notice %></div><% end %>
      <% if alert.present? %><div class="flash alert"><%= alert %></div><% end %>
      <%= yield %>
    </main>
    <%= yield :body_scripts %>
  </body>
</html>

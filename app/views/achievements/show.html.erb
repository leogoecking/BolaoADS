<div class="actions">
  <div>
    <p class="page-kicker">🔥 Badges da campanha</p>
    <h1 class="page-title">Conquistas pra ostentar</h1>
  </div>
</div>

<div class="hype-card">
  <p class="font-black text-slate-950">Badge nao da ponto, mas da argumento na resenha. 😎</p>
  <p class="muted">Conquistas sao decorativas e nao alteram a pontuacao do ranking.</p>
</div>

<div class="achievement-grid mt-4">
  <% @achievements.each do |achievement| %>
    <% unlocked = @unlocked_by_key[achievement.key] %>
    <article class="achievement-card <%= "achievement-card-unlocked" if unlocked %>">
      <div class="achievement-icon" aria-hidden="true"><%= achievement_icon(achievement) %></div>
      <div class="achievement-content">
        <div class="achievement-heading">
          <h2><%= achievement.name %></h2>
          <% if unlocked %>
            <span class="status-pill status-open">Liberada</span>
          <% else %>
            <span class="status-pill status-closed">Bloqueada</span>
          <% end %>
        </div>
        <p class="text-slate-700"><%= achievement.description %></p>
        <% if unlocked %>
          <p class="achievement-meta">Liberada em <%= l(unlocked.unlocked_at, format: :short) %></p>
        <% else %>
          <p class="achievement-meta">Continue palpitando para destravar.</p>
        <% end %>
      </div>
    </article>
  <% end %>
</div>
